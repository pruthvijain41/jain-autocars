rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Read access for all public data
    match /cars/{carId} {
      allow read;
      allow write: if request.auth != null;
    }

    match /inquiries/{inquiryId} {
      allow create;
      allow read, update, delete: if request.auth != null;
    }

    // --- THIS IS THE NEW RULE BLOCK THAT FIXES THE ERROR ---
    match /testimonials/{testimonialId} {
      // Allow anyone to submit (create) a new testimonial.
      allow create;
      
      // Only allow reading testimonials if they have been approved by an admin.
      allow read: if resource.data.approved == true;
      
      // Only allow authenticated admins to update (approve) or delete testimonials.
      allow update, delete: if request.auth != null;
    }
    // ----------------------------------------------------

    match /showroomInfo/{docId} {
      allow read;
      allow write: if request.auth != null;
    }

    // Admin users collection (if you have one for roles/permissions)
    match /adminUsers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}