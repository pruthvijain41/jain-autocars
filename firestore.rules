rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Read access for all public data
    match /cars/{carId} {
      allow read;
      allow write: if request.auth != null;
    }

    match /inquiries/{inquiryId} {
      allow create;
      allow read, update, delete: if request.auth != null;
    }

    match /testDrives/{testDriveId} {
      allow create;
      allow read, update, delete: if request.auth != null;
    }

    match /testimonials/{testimonialId} {
      // Allow anyone to submit a new testimonial.
      allow create;

      // Public users can only read approved testimonials.
      // Authenticated admins can read all (including pending).
      allow read: if request.auth != null || resource.data.approved == true;

      // Only authenticated admins can update or delete testimonials.
      allow update, delete: if request.auth != null;
    }

    match /showroomInfo/{docId} {
      allow read;
      allow write: if request.auth != null;
    }

    // Admin users collection (if you have one for roles/permissions)
    match /adminUsers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}